#!/bin/bash

# Check if PYFILE is set
if [ -z "$PYFILE" ]; then
    echo "PYFILE environment variable is not set."
    exit 1
fi

# Extract the filename (without path) for output naming
PYFILE_BASENAME=$(basename "$PYFILE")

# Print the "Compiling ..." message (like in the example)
echo "Compiling $PYFILE_BASENAME ..."

# Compile to bytecode
python3 -m py_compile "$PYFILE"

# Move the generated .pyc file to the current directory with correct name
mv __pycache__/"${PYFILE_BASENAME}"*.pyc "${PYFILE_BASENAME}c"

# Optional: Cleanup empty __pycache__
rmdir __pycache__ 2>/dev/null

